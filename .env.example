# ---- Required ----
GEMINI_API_KEY=your_gemini_api_key_here

# ---- Optional: Firestore persistence ----
# FIREBASE_CREDENTIALS=/path/to/serviceAccountKey.json

# ---- Optional: Firebase Auth (leave blank to use demo-user) ----
# FIREBASE_PROJECT_ID=your_project_id

# ---- Optional: CORS (comma-separated, defaults to localhost:5173) ----
ALLOWED_ORIGINS=http://localhost:5173,https://your-deployed-frontend.web.app

# ---- Optional: Gemini model override ----
# GEMINI_MODEL=gemini-2.0-flash

# ---- Optional: Cloud Scheduler secret ----
# CRON_SECRET=your_secret_here
